{
  "name": "simple-my-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Oii Woof",
  "license": "MIT",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs && pagefind --site docs/.vitepress/dist",
    "serve": "vitepress serve docs",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "vp lint docs/.vitepress",
    "lint:fix": "vp lint docs/.vitepress --fix",
    "fmt": "vp fmt docs/.vitepress",
    "fmt:fix": "vp fmt docs/.vitepress --fix",
    "lint:md": "markdownlint docs/**/*.md --ignore docs/.vitepress",
    "check": "vp check"
  },
  "dependencies": {
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.12.1",
    "vue": "3.5.12"
  },
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@voidzero-dev/vite-plus-core": "^0.1.11",
    "markdownlint-cli": "^0.45.0",
    "pagefind": "^1.3.0",
    "typescript": "^5.4.5",
    "unocss": "^66.6.6",
    "vite-plus": "^0.1.11",
    "vitepress": "1.6.4",
    "vitepress-plugin-group-icons": "^1.7.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search",
        "search-insights"
      ]
    }
  }
}
